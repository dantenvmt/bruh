# ===========================================
# Multi-API Job Aggregator - Environment Config
# ===========================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to git!

# Host user/group used by docker-compose service containers writing to bind mounts.
# Set to your EC2 user IDs to avoid root-owned files (e.g., in ./data).
UID=1000
GID=1000

# -----------------
# Database Settings (REQUIRED)
# -----------------
POSTGRES_USER=jobscraper
POSTGRES_PASSWORD=
POSTGRES_DB=jobscraper

# Optional: override the DB connection string used by the API/scheduler/migrations.
# Useful for managed Postgres (e.g., Supabase). If set, this overrides the local Docker DB DSN.
# Example: JOB_SCRAPER_DB_DSN=postgresql+psycopg://user:pass@host:5432/dbname?sslmode=require
JOB_SCRAPER_DB_DSN=

# -----------------
# Scheduler Settings
# -----------------
# Time to run daily job ingestion (24-hour format)
JOB_SCRAPER_SCHEDULE_HOUR=23
JOB_SCRAPER_SCHEDULE_MINUTE=59
# Optional scheduler source controls
# Include list (if set): scheduler only runs these
JOB_SCRAPER_SCHEDULE_SOURCES=
# Exclude list (default keeps Ashby on dedicated scheduler)
JOB_SCRAPER_SCHEDULE_EXCLUDE_SOURCES=ashby

# Days to keep old job records
JOB_SCRAPER_RETENTION_DAYS=30

# Filter for US-only jobs
JOB_SCRAPER_US_ONLY=true
# Drop jobs older than this many days when posted_date is available
JOB_SCRAPER_MAX_POSTING_AGE_DAYS=60

# -----------------
# Custom Scraper Discovery Gates
# -----------------
# Confidence floor for auto-detected selectors (0.0-1.0)
JOB_SCRAPER_SELECTOR_MIN_CONFIDENCE=0.6
# Minimum jobs extracted during selector validation
JOB_SCRAPER_SELECTOR_MIN_JOBS=3
# Require manual approval before custom sites are scraped
JOB_SCRAPER_REQUIRE_APPROVED_SELECTORS=true
# If primary fetch mode fails, try the other mode (static <-> browser)
JOB_SCRAPER_HYBRID_BROWSER_FALLBACK=true

# -----------------
# API Settings
# -----------------
# Optional: include one or more extra YAML config files (comma-separated paths).
# Useful for large ATS target lists generated by `python scripts/build_seed.py --all`.
# Activate the 14k company seed (Greenhouse/Lever/Ashby/Workday):
# JOB_SCRAPER_CONFIG_INCLUDES=data/seed_config.yaml
JOB_SCRAPER_CONFIG_INCLUDES=

# Bi-weekly seed refresh (runs on the 1st and 15th at 03:00 UTC via scheduler)
# Requires GROQ_API_KEY to be set. Safe to leave false in development.
JOB_SCRAPER_ENABLE_SEED_REFRESH=false

# -----------------
# Redis (optional)
# -----------------
# If set, enables Redis-backed rate limiter persistence and LLM parse result caching.
# Leave empty to use in-memory fallbacks (suitable for single-instance deployments).
REDIS_URL=

# CORS origins (comma-separated, for frontend access)
# Frontend dev server is fixed at port 5173.
JOB_SCRAPER_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Rate limiting
JOB_SCRAPER_RATE_LIMIT=60/minute

# API Key protection (REQUIRED for production)
JOB_SCRAPER_API_KEY=
JOB_SCRAPER_REQUIRE_API_KEY=true

# -----------------
# Security Settings
# -----------------
# Store raw payloads (disable for production)
JOB_SCRAPER_STORE_RAW_PAYLOAD=false

# Skip TLS verification for database connections (development only)
JOB_SCRAPER_SKIP_DSN_TLS_CHECK=false

# Enable HTTP Strict Transport Security headers
JOB_SCRAPER_ENABLE_HSTS=false

# Sanitize HTML content in job descriptions
JOB_SCRAPER_SANITIZE_HTML=true

# -----------------
# Job Source API Keys
# -----------------
# Adzuna (https://developer.adzuna.com/)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# USAJobs (https://developer.usajobs.gov/)
USAJOBS_API_KEY=
USAJOBS_USER_AGENT=your-email@example.com

# The Muse (https://www.themuse.com/developers)
THEMUSE_API_KEY=

# Findwork (https://findwork.dev/)
FINDWORK_API_KEY=

# CareerOneStop (https://www.careeronestop.org/Developers/)
CAREERONESTOP_API_KEY=
CAREERONESTOP_USER_ID=

# RapidAPI / JSearch (https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch)
RAPIDAPI_KEY=

# Greenhouse (comma-separated board tokens)
GREENHOUSE_BOARDS=

# Lever (comma-separated site names)
LEVER_SITES=

# SmartRecruiters (comma-separated company slugs)
# Example board URL: https://jobs.smartrecruiters.com/Uber  -> SMARTRECRUITERS_COMPANIES=uber
SMARTRECRUITERS_COMPANIES=
SMARTRECRUITERS_INCLUDE_CONTENT=false
SMARTRECRUITERS_REQUESTS_PER_MINUTE=60

# Ashby (comma-separated company slugs)
# Example board URL: https://jobs.ashbyhq.com/notion -> ASHBY_COMPANIES=notion
ASHBY_COMPANIES=
ASHBY_INCLUDE_CONTENT=false
ASHBY_REQUESTS_PER_MINUTE=60

# Dedicated Ashby batch scheduler (optional, separate from main ingest)
# Split into two non-overlapping lists (target ~500 each)
ASHBY_BATCH_A_COMPANIES=
ASHBY_BATCH_B_COMPANIES=
ASHBY_BATCH_A_HOUR=6
ASHBY_BATCH_A_MINUTE=0
ASHBY_BATCH_B_HOUR=18
ASHBY_BATCH_B_MINUTE=0
ASHBY_BATCH_MAX_PER_SOURCE=999999
ASHBY_BATCH_QUERY=
ASHBY_BATCH_LOCATION=
ASHBY_BATCH_DRY_RUN=false

# We Work Remotely RSS (optional override)
WEWORKREMOTELY_BASE_URL=https://weworkremotely.com/remote-jobs.rss

# Built In (optional; leave empty to use defaults in code)
BUILTIN_DOMAINS=
BUILTIN_MAX_PAGES=5
BUILTIN_REQUESTS_PER_MINUTE=60

# Visa/H1B/OPT tagging (best-effort; not a guarantee of sponsorship)
JOB_SCRAPER_VISA_TAGGING_ENABLED=true
# Optional: comma-separated list of sponsor-friendly companies
JOB_SCRAPER_VISA_SPONSOR_COMPANIES=
# Optional: path to a newline-delimited file of sponsor-friendly companies
JOB_SCRAPER_VISA_SPONSOR_COMPANIES_FILE=
